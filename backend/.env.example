# Google Gemini API
ZAI_API_KEY=your_google_api_key_here
ZAI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-pro:generateContent
ZAI_MODEL=gemini-2.5-pro

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@127.0.0.1:5432/coordina

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# App
APP_ENV=development
APP_SECRET_KEY=change_this_to_a_random_secret
CORS_ORIGINS=http://localhost:5173

# File Uploads
MAX_UPLOAD_SIZE_MB=20
UPLOAD_DIR=./uploads
